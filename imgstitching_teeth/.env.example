# AlphaDent 模型配置
# 下载地址：请联系 AlphaDent 官方或使用项目提供的链接
DENTAL_SEG_WEIGHTS=/path/to/your/alphadent_9cls_960.pt

# U-Net 模型配置（可选）
# 如果要使用 U-Net 分割，请准备模型文件并设置路径
# 参考 UNET_QUICKSTART.md 了解如何获取或创建 U-Net 模型
UNET_WEIGHTS=/path/to/your/unet_model.pth

# Hunyuan3D 3D Demo 配置（第 1 阶段）
# 第一版建议单独启动本地 Hunyuan3D 服务，再让本项目通过 HTTP 调用
HUNYUAN3D_SERVICE_URL=http://127.0.0.1:8081
HUNYUAN3D_SERVICE_HOST=127.0.0.1
HUNYUAN3D_SERVICE_PORT=8081
HUNYUAN3D_MODEL_PATH=tencent/Hunyuan3D-2mv
HUNYUAN3D_SUBFOLDER=hunyuan3d-dit-v2-mv-turbo
HUNYUAN3D_DEVICE=auto
# 0 表示任务完成后立刻卸载模型，适合 16GB Mac 这类统一内存机器
# 如果你希望连续多次生成更快，可以改成 300、600 之类的秒数
HUNYUAN3D_KEEPALIVE_SEC=0
HUNYUAN3D_SERVICE_MODE=mv_bridge
HUNYUAN3D_REQUEST_TIMEOUT_SEC=20
HUNYUAN3D_POLL_INTERVAL_SEC=3
